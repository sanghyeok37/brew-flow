# 1. 서버 및 멀티파트 설정
spring:
  profiles:
    active: local # 기본적으로 local 프로파일 활성화
  threads:
    virtual:
      enabled: true  # Java 21 Virtual Thread 활성화

  servlet:
    multipart:
      enabled: true
      max-file-size: 10MB
      max-request-size: 10MB

  # 2. DB 설정 (MySQL)
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: ${SPRING_DATASOURCE_URL}
    username: ${SPRING_DATASOURCE_USERNAME}
    password: ${SPRING_DATASOURCE_PASSWORD}
    hikari:
      maximum-pool-size: 20
      minimum-idle: 5
      pool-name: BrewFlow-HikariCP
      connection-timeout: 3000

# 3. MyBatis 설정 (패키지 경로 수정)
mybatis:
  # DTO, VO가 모여있는 패키지 경로 (패키지명에 맞게 수정)
  type-aliases-package: com.brewflow.backend.dto,com.brewflow.backend.vo
  configuration:
    map-underscore-to-camel-case: true
    jdbc-type-for-null: "NULL"
  # 매퍼 XML 위치 (src/main/resources/mapper 폴더 안에 넣을 예정)
  mapper-locations: classpath:mapper/**/*.xml

# 4. Swagger (SpringDoc) 설정
springdoc:
  api-docs:
    enabled: true
  packages-to-scan: com.brewflow.backend.controller
  swagger-ui:
    path: /api.html

# 5. 커스텀 설정 (JWT, 이메일 등)
custom:
  jwt:
    key-str: 
    issuer: BrewFlow
    expiration: 86400000
    refresh-expiration: 28
    renewal-limit: 10

# 6. 로깅 설정 (패키지명에 맞게 수정)
logging:
  level:
    root: WARN
    com.brewflow.backend: DEBUG # 프로젝트 로그는 상세히!