spring:
  profiles:
    active: local # 기본적으로 로컬 환경을 사용하도록 설정

  # 공통 설정 (데이터 크기 등은 배포나 로컬이나 비슷하니까요)
  servlet:
    multipart:
      enabled: true
      max-file-size: 10MB

  # DB 접속 구조 (설계도)
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: ${DB_URL:jdbc:mysql://localhost:3306/brew_flow?allowPublicKeyRetrieval=true&useSSL=false}
    username: ${DB_USERNAME:root}
    password: ${DB_PASSWORD:}

# 3. MyBatis 설정 (패키지 경로 수정)
mybatis:
  # DTO, VO가 모여있는 패키지 경로 (패키지명에 맞게 수정)
  type-aliases-package: com.brewflow.backend.dto,com.brewflow.backend.vo
  configuration:
    map-underscore-to-camel-case: true
    jdbc-type-for-null: "NULL"
  # 매퍼 XML 위치 (src/main/resources/mapper 폴더 안에 넣을 예정)
  mapper-locations: classpath:mapper/**/*.xml

# 4. Swagger (SpringDoc) 설정
springdoc:
  api-docs:
      enabled: true
  packages-to-scan: com.brewflow.backend.controller
  swagger-ui:
  path: /api.html

# 5. 커스텀 설정 (JWT, 이메일 등)
custom:
  jwt:
  key-str: ekadnjsrpdlaldsjrnflzosldjstyapdlzjrhtmxmqpflf2020
  issuer: BrewFlow
  expiration: 86400000
  refresh-expiration: 28
  renewal-limit: 10

		# 6. 로깅 설정 (패키지명에 맞게 수정)
		logging:
		  level:
		    root: WARN
		    com.brewflow.backend: DEBUG # 프로젝트 로그는 상세히!
