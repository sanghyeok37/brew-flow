# ==========================================
# BrewFlow Monorepo Global Gitignore
# ==========================================

# --- OS Specific ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE Specific ---
.metadata/
.idea/
.vscode/
*.swp
*.swo
.metadata/
.settings/
.classpath
.project
.factorypath
.springBeans
.sts4-cache/
*.iml

# --- Build & Output ---
bin/
out/
build/
dist/
target/
.gradle/
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# --- Dependencies ---
node_modules/
jspm_packages/
.pnp/
.pnp.js

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Backend (Spring/Gradle) ---
backend/.gradle/
backend/build/
backend/bin/
backend/out/
backend/src/main/resources/application-local.yml
backend/src/main/resources/application-local.properties
backend/src/main/resources/application-secret.yml
backend/src/main/resources/application-secret.properties
backend/HELP.md

# --- Frontend (React/Vite) ---
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
!frontend/.env.example

# --- Temporary & Backup ---
backend_old/
sandbox/
*.bak
*.tmp
*.old

# --- Others ---
.DS_Store
.netrwhist
