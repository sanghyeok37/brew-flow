# ==========================================
# BrewFlow Monorepo Global Gitignore
# ==========================================

# --- OS / IDE ---
.DS_Store
.idea/
.vscode/
*.swp

# --- Eclipse / STS Specific ---
.metadata/
.settings/
.classpath
.project
.factorypath
.springBeans
.sts4-cache/
bin/

# --- 빌드 및 실행 결과물 ---
**/build/
**/bin/
**/out/
**/.gradle/
*.jar

# --- 백엔드 (Secrets 방어) ---
backend/src/main/resources/application-*.yml
backend/src/main/resources/application-*.properties
backend/HELP.md

# --- 프론트엔드 ---
**/node_modules/
**/dist/
frontend/.env*
!frontend/.env.example

# --- 로그 ---
*.log