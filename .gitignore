# ==========================================
# BrewFlow Monorepo Global Gitignore
# ==========================================

# --- OS / IDE (Common) ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.bak
*.tmp

# --- Eclipse / STS Specific ---
.metadata/
.settings/
.classpath
.project
.factorypath
.springBeans
.sts4-cache/
bin/
*/.settings/
*/.classpath
*/.project

# --- Backend (Spring Boot / Gradle) ---
backend/.gradle/
backend/build/
backend/bin/
backend/out/
backend/.gradle-proxy-config
backend/src/main/resources/application-*.yml
backend/src/main/resources/application-*.properties
backend/*.jar
backend/HELP.md

# --- Frontend (React / Vite) ---
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local
frontend/.env
frontend/.env.*
!frontend/.env.example

# --- Logs ---
*.log
logs/